{
  "name": "ib-flex-cli",
  "version": "0.1.0",
  "description": "CLI for pulling IBKR portfolio data via the Flex Web Service",
  "license": "MIT",
  "author": "Hicham Kazan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hishamank/ib-flex-cli.git"
  },
  "bugs": {
    "url": "https://github.com/hishamank/ib-flex-cli/issues"
  },
  "homepage": "https://github.com/hishamank/ib-flex-cli#readme",
  "keywords": [
    "ibkr",
    "interactive-brokers",
    "flex",
    "flex-query",
    "portfolio",
    "cli"
  ],
  "type": "module",
  "packageManager": "pnpm@10.28.1",
  "bin": {
    "ibkr": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "ibkr": "tsx src/cli.ts",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}

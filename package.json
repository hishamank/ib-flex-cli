{
  "name": "ib-flex-cli",
  "version": "0.1.0",
  "description": "CLI for pulling IBKR portfolio data via the Flex Web Service",
  "type": "module",
  "bin": {
    "ib": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "ib": "tsx src/cli.ts",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}

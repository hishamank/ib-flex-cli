# Copy to .env (which is gitignored) and fill in.
# Generate the token in IBKR Client Portal:
#   Settings -> Account Settings -> Reporting -> Flex Web Service Configuration
# The token expires (~1 year) and must be rotated.
IB_FLEX_TOKEN=

# Optional overrides:
# IB_FLEX_CONFIG=config.json
# IB_FLEX_DB=ib-flex.db
